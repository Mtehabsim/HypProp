# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Project outputs (regenerated by run_all.sh; can be large)
results/
raw_data/
*.pt
*.log

# ...but DO keep the small, decisive result artifacts (CSVs, verdicts, plots).
# These are KB-sized and are the actual evidence worth version-controlling.
# The huge activations (*.pt, ignored above) and logs are never committed.
!results/
results/*
!results/geometry/
results/geometry/*
!results/geometry/*.csv
!results/geometry/*.md
!results/geometry/*.png
!results/eval/
results/eval/*
!results/eval/*.csv
!results/eval/*.md
!results/eval/*.json
!results/determinants/
results/determinants/*
!results/determinants/*.csv
!results/determinants/*.png
!results/security/
results/security/*
!results/security/*.csv
!results/security/*.png
!results/security/*.json

# DGX git-bridge: dgx_results/ holds shipped-back evidence (CSVs, verdicts,
# job.log). The global *.log rule must not block them, so they are un-ignored.
!dgx_results/
!dgx_results/**
dgx_results/**/*.oversize.local
.dgx_agent.pid

# Environments
.venv/
venv/
env/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
